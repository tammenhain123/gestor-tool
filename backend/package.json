{
  "name": "gestortool-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:local": "cross-env NODE_ENV=dev ts-node -r tsconfig-paths/register src/main.ts",

    "start:prod": "node dist/main.js",
    "start:prod-local": "cross-env NODE_ENV=prod node dist/main.js",
    "docker:db": "docker-compose -f docker-compose.dev.yml up -d",
    "seed:master:prod": "node dist/scripts/seed-master.js",
    "typeorm:migration:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/data-source.ts src/migrations/$npm_config_name",
    "typeorm:migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
    "typeorm:migration:create": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:create -d src/data-source.ts src/migrations/$npm_config_name"
  },
  "typeorm": {
    "migrationsDir": "src/migrations"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "axios": "^1.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.0",
    "jwks-rsa": "^2.1.5",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.5.1",
    "@types/passport-jwt": "^4.0.1",
    "ts-node": "^10.9.1",
    "cross-env": "^7.0.3",
    "typescript": "^5.3.3"
  }
}
